# Blink Engine — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ─── WebSocket & REST endpoints ──────────────────────────────────────────────

CLOB_HOST=https://clob.polymarket.com
WS_URL=wss://ws-live-data.polymarket.com
GAMMA_API=https://gamma-api.polymarket.com

# ─── Tracking target ─────────────────────────────────────────────────────────

# Lowercase hex wallet address of the RN1 wallet to track
RN1_WALLET=0x2005d16a84ceefa912d4e380cd32e7ff827875ea

# ─── Markets ─────────────────────────────────────────────────────────────────

# Comma-separated Polymarket token IDs to subscribe to.
# Run `cargo run -p market-scanner` to discover current markets.
MARKETS=REPLACE_WITH_TOKEN_IDS

# ─── Operating mode ──────────────────────────────────────────────────────────

# Set to true to simulate orders with $100 virtual USDC (no real funds used).
PAPER_TRADING=true

# Set to true to enable the ratatui TUI dashboard.
# Requires PAPER_TRADING=true. Tracing output is redirected to logs/engine.log.
TUI=true

# Optional: start TUI with modern theme enabled by default.
# You can always toggle live with [t].
TUI_MODERN_THEME=false

# Paper portfolio persistence path (history + open positions).
PAPER_STATE_PATH=logs/paper_portfolio_state.json

# Autosave interval in seconds for paper portfolio state.
PAPER_AUTOSAVE_SECS=10

# Set to true to submit real orders via the Polymarket CLOB REST API.
# All credential fields below MUST be set when LIVE_TRADING=true.
LIVE_TRADING=false

# Canonical live profile contract. Required to be canonical-v1 in live mode.
BLINK_LIVE_PROFILE=canonical-v1
LIVE_ROLLOUT_STAGE=1
LIVE_CANARY_MAX_ORDER_USDC=5.0
LIVE_CANARY_MAX_ORDERS_PER_SESSION=20
LIVE_CANARY_DAYTIME_ONLY=true
LIVE_CANARY_START_HOUR_UTC=8
LIVE_CANARY_END_HOUR_UTC=22
LIVE_CANARY_MAX_REJECT_STREAK=3
# LIVE_CANARY_ALLOWED_MARKETS=12345,67890

# ─── Agent JSON-RPC control plane (optional) ──────────────────────────────────
#
# Enables a local JSON-RPC endpoint on HTTP POST /rpc for agent orchestration.
# Methods:
#   - blink_status  (overall engine + paper status)
#   - paper_summary (paper execution KPIs)
#   - set_pause     (params: {"paused": true|false})
AGENT_RPC_ENABLED=false
AGENT_RPC_BIND=127.0.0.1:7878

# ─── Live trading credentials (required when LIVE_TRADING=true) ──────────────

# 64-character hex secp256k1 private key used to sign EIP-712 orders.
# SIGNER_PRIVATE_KEY=

# Your Polymarket funder / proxy-wallet address (the order `maker`).
# POLYMARKET_FUNDER_ADDRESS=

# Polymarket L2 API credentials (obtain via createOrDeriveApiKey).
# POLYMARKET_API_KEY=
# POLYMARKET_API_SECRET=
# POLYMARKET_API_PASSPHRASE=
# POLYMARKET_SIGNATURE_TYPE=0
# POLYMARKET_ORDER_NONCE=0
# POLYMARKET_ORDER_EXPIRATION=0

# ─── Risk management ─────────────────────────────────────────────────────────

# Master kill switch — must be explicitly true to allow live order submission.
TRADING_ENABLED=false

# Maximum daily loss as a fraction of starting NAV (0.10 = 10%).
MAX_DAILY_LOSS_PCT=0.10

# Maximum number of simultaneous open positions.
# Set to 0 for unlimited.
MAX_CONCURRENT_POSITIONS=0

# Maximum USDC per single order.
MAX_SINGLE_ORDER_USDC=20.0

# Maximum orders per second (CLOB rate-limit safety).
MAX_ORDERS_PER_SECOND=3

# ─── Autoclaim (paper mode) ───────────────────────────────────────────────────

# Automatically close paper positions when unrealized PnL reaches target.
AUTOCLAIM_ENABLED=true

# Percent gain threshold for autoclaim (100 = +100% / "to win reached").
AUTOCLAIM_TARGET_PNL_PCT=100

# Tiered autoclaim format: "pnlPct:fraction,pnlPct:fraction,..."
# Example below means close 30% at +40%, 30% at +70%, then remaining at +100%.
AUTOCLAIM_TIERS=40:0.30,70:0.30,100:1.0

# Optional Twin-specific autoclaim threshold override.
# If unset, Blink Twin uses AUTOCLAIM_TARGET_PNL_PCT.
TWIN_AUTOCLAIM_TARGET_PNL_PCT=100

# Optional Twin-specific tiered autoclaim override.
# If unset, Blink Twin uses AUTOCLAIM_TIERS.
TWIN_AUTOCLAIM_TIERS=40:0.30,70:0.30,100:1.0

# ─── Stop-loss (paper mode) ───────────────────────────────────────────────────

# Automatically close positions that have lost more than STOP_LOSS_PCT percent.
# Works alongside autoclaim; prevents runaway losers from wiping capital.
STOP_LOSS_ENABLED=true

# Maximum unrealized loss (%) before a position is force-closed.
# E.g. 35 = cut any position down more than 35%.
STOP_LOSS_PCT=35

# Tiered stop-loss for small positions: apply a tighter cut for positions whose
# cost basis is below STOP_LOSS_SMALL_NOTIONAL_USDC to limit absolute dollar loss.
# Default: 20% cut for positions < $6 cost (vs 35% for larger positions).
STOP_LOSS_SMALL_PCT=20
STOP_LOSS_SMALL_NOTIONAL_USDC=6

# Cooldown (seconds) to block a token from re-entry after a drift abort.
# Prevents cascading aborts when a market moves sharply during a live event.
DRIFT_ABORT_COOLDOWN_SECS=30

# Price-confidence sizing discount: reduce entry size for mid-range prices (near 0.5)
# where outcome uncertainty is highest. 0.0 = no discount, 0.35 = up to 35% reduction
# at price=0.5, tapering to 0% at prices near 0.0 or 1.0.
PAPER_CONFIDENCE_DISCOUNT=0.35

# Paper fill simulation latency (ms). 0 = immediate fill (fastest).
PAPER_FILL_WINDOW_MS=0

# Poll interval (ms) used only when PAPER_FILL_WINDOW_MS > 0.
PAPER_FILL_CHECK_INTERVAL_MS=100

# Paper sizing controls (aggressive defaults for better fill participation).
# Base mirror notional multiplier (0.20 = 20% of RN1 notional).
PAPER_SIZE_MULTIPLIER=0.20
# Max size per trade as % of current NAV (0.25 = 25%).
PAPER_MAX_POSITION_PCT=0.25
# Max exposure per token as % of NAV (concentration cap).
PAPER_TOKEN_MAX_EXPOSURE_PCT=0.20
# Absolute minimum order floor in USDC (applied before caps).
PAPER_MIN_ORDER_FLOOR_USDC=8

# Minimum paper trade size in USDC (used by liquidity guard fallback downsizing).
PAPER_MIN_TRADE_USDC=5

# Fraction of top-of-book depth that the paper engine is allowed to capture.
# 0.90 means use up to 90% of displayed top level when downsizing.
PAPER_DEPTH_CAPTURE_RATIO=0.90

# When the book is too thin (or missing side), fallback order size in USDC.
PAPER_THIN_BOOK_FALLBACK_USDC=6

# Set true to restore strict hard-reject behavior on thin books.
PAPER_LIQUIDITY_HARD_REJECT=false

# Strict realism mode for paper simulation.
# true = conservative assumptions closer to real fills and exits.
PAPER_REALISM_MODE=true

# Adverse entry fill adjustment in basis points (applied against you).
# Simulates latency disadvantage vs RN1 — you always arrive later.
PAPER_ADVERSE_FILL_BPS=20

# Taker fee in basis points applied on entry and exit notional.
# Polymarket CLOB taker fee is ~100 bps (1%) per side.
PAPER_TAKER_FEE_BPS=100

# Conservative mark-to-market haircut in basis points for unrealized NAV.
PAPER_EXIT_HAIRCUT_BPS=25

# Fill-latency SLO breach threshold for p99 (microseconds).
FILL_SLO_P99_US=250000

# Warm-state and analytics persistence paths.
PAPER_WARM_STATE_PATH=logs/paper_warm_state.json
PAPER_REJECTIONS_PATH=logs/paper_rejections.json

# A/B experiment toggles (runtime can override via TUI).
EXPERIMENT_SIZING_B=false
EXPERIMENT_AUTOCLAIM_B=false
EXPERIMENT_DRIFT_B=false

# Optional adversarial twin engine (disabled by default to avoid inflated latency stats).
BLINK_TWIN=false

# Enable ClickHouse warehouse for real-time execution quality analytics.
# Leave empty to disable.
CLICKHOUSE_URL=

# ─── Dynamic VaR ─────────────────────────────────────────────────────────────

# Rolling window in seconds for Value-at-Risk exposure tracking.
VAR_WINDOW_SECS=60

# VaR circuit-breaker threshold — trip if rolling exposure > this % of NAV.
VAR_THRESHOLD_PCT=0.05

# ─── In-play failsafe ────────────────────────────────────────────────────────

# Maximum price drift (basis points) during the pre-order countdown.
# 150 = 1.5%. If exceeded, the order is aborted.
PRICE_DRIFT_ABORT_BPS=150

# Poll interval in milliseconds during the failsafe countdown.
FAILSAFE_POLL_INTERVAL_MS=100

# Countdown duration in seconds before submitting a live order.
FAILSAFE_COUNTDOWN_SECS=3

# ─── Game-start watcher ──────────────────────────────────────────────────────

# How often (milliseconds) to poll CLOB prices for in-play detection.
GAME_WATCHER_INTERVAL_MS=500

# ─── Kernel telemetry (eBPF) ───────────────────────────────────────────────────
#
# By default the engine attempts to attach kernel telemetry at startup.
# On Windows/macOS (or Linux builds without ebpf feature), it gracefully falls
# back to N/A in TUI without crashing.
#
# Set explicitly to false to disable attach attempts.
EBPF_TELEMETRY=true
#
# Linux launch note:
# Build with feature enabled:
#   cargo build -p engine --release --features bpf-probes/ebpf-telemetry

# ─── Logging ─────────────────────────────────────────────────────────────────

# Logs are always persisted by the engine:
# - logs/engine.log
# - logs/sessions/engine-session-YYYYMMDD-HHMMSS.log (one file per run)
# - logs/LATEST_SESSION_LOG.txt (path to latest session log)
#
# Tracing filter directive. Examples: info | debug | engine=debug,warn
LOG_LEVEL=info

# Debounce forced WebSocket reconnect requests (milliseconds).
WS_RECONNECT_DEBOUNCE_MS=1500

# Max chars of raw WS payload preview logged on parse failures.
WS_PARSE_ERROR_PREVIEW_CHARS=120

# Auto-generate a structured post-run evaluation report at shutdown.
# Enabled by default if unset.
AUTO_POSTRUN_REVIEW=true

# Output directory for post-run reports.
POSTRUN_REVIEW_DIR=logs/reports

# ── Web UI ──────────────────────────────────────────────────────────
# Enable the Axum web UI server.
WEB_UI=true
# Port to serve the web UI on (also used by Vite dev proxy in blink-ui).
WEB_UI_PORT=3030
# Path to the built dashboard (blink-ui build output).
WEB_UI_STATIC_DIR=static/ui

# ─── Smart Money Signals ─────────────────────────────────────────────────────
#
# Polls Polymarket leaderboard for top traders and emits signals on their
# significant trades. Signals are forwarded into the engine's signal bus.

# Set to true to activate the smart money poller.
SMART_MONEY_ENABLED=false

# Number of top wallet addresses to track (from leaderboard).
SMART_MONEY_TOP_N=20

# Minimum USD trade size to emit a signal (smaller trades are ignored).
SMART_MONEY_MIN_TRADE_USD=500

# Poll interval in milliseconds.
SMART_MONEY_POLL_MS=5000

# ─── Market Discovery ────────────────────────────────────────────────────────
#
# Continuously discovers active markets via Polymarket Gamma API and feeds
# token IDs into the engine's WS subscription list.

# Set to true to activate market discovery.
DISCOVERY_ENABLED=false

# Comma-separated lenses: all | sports | crypto | politics | geo
DISCOVERY_LENS=all

# Minimum USD liquidity to include a market.
DISCOVERY_MIN_LIQUIDITY=10000

# Minimum 24h USD volume to include a market.
DISCOVERY_MIN_VOLUME=5000

# Maximum number of concurrently subscribed markets via discovery.
DISCOVERY_MAX_MARKETS=50

# How often (seconds) to refresh the discovered market list.
DISCOVERY_REFRESH_SECS=300

# ─── Bullpen Intelligence ────────────────────────────────────────────────────
#
# Bullpen CLI provides market discovery, smart money signals, and convergence
# alerts. Requires bullpen CLI installed in WSL (on Windows) or natively.
# One-time auth: wsl -d Ubuntu -- bullpen auth login
#
# Master toggle — set to true to activate the Bullpen bridge.
BULLPEN_ENABLED=true
#
# Enable the continuous market discovery scheduler.
BULLPEN_DISCOVER_ENABLED=true
#
# On Windows, set to the WSL invocation path (default shown below).
# BULLPEN_CLI_PATH=wsl -d Ubuntu -- bullpen
# BULLPEN_USE_WSL=true
#
# Per-command timeout (seconds). Increase on slow WSL startup.
BULLPEN_TIMEOUT_SECS=30
#
# Discovery scan interval (seconds, default: 300 = 5 min).
# BULLPEN_DISCOVER_INTERVAL_SECS=300
#
# Comma-separated lenses to use (sports, crypto, traders, geo, politics).
# BULLPEN_DISCOVER_LENSES=sports,crypto,traders
#
# Max markets to return per lens scan.
# BULLPEN_DISCOVER_LIMIT=50

# ─── Blink CLI ───────────────────────────────────────────────────────────────
#
# Base URL for the blink-cli to reach the engine REST API.
# Default: http://localhost:3030 (matches WEB_UI_PORT above).
# Override here or set in the shell before running `blink`.
# BLINK_HOST=http://localhost:3030
