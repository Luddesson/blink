# Blink Engine — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ─── WebSocket & REST endpoints ──────────────────────────────────────────────

CLOB_HOST=https://clob.polymarket.com
WS_URL=wss://ws-live-data.polymarket.com
GAMMA_API=https://gamma-api.polymarket.com

# ─── Tracking target ─────────────────────────────────────────────────────────

# Lowercase hex wallet address of the RN1 wallet to track
RN1_WALLET=0x2005d16a84ceefa912d4e380cd32e7ff827875ea

# ─── Markets ─────────────────────────────────────────────────────────────────

# Comma-separated Polymarket token IDs to subscribe to.
# Run `cargo run -p market-scanner` to discover current markets.
MARKETS=REPLACE_WITH_TOKEN_IDS

# ─── Operating mode ──────────────────────────────────────────────────────────

# Set to true to simulate orders with $100 virtual USDC (no real funds used).
PAPER_TRADING=true

# Set to true to enable the ratatui TUI dashboard.
# Requires PAPER_TRADING=true. Tracing output is redirected to logs/engine.log.
TUI=true

# Set to true to submit real orders via the Polymarket CLOB REST API.
# All credential fields below MUST be set when LIVE_TRADING=true.
LIVE_TRADING=false

# ─── Live trading credentials (required when LIVE_TRADING=true) ──────────────

# 64-character hex secp256k1 private key used to sign EIP-712 orders.
# SIGNER_PRIVATE_KEY=

# Your Polymarket funder / proxy-wallet address (the order `maker`).
# POLYMARKET_FUNDER_ADDRESS=

# Polymarket L2 API credentials (obtain via createOrDeriveApiKey).
# POLYMARKET_API_KEY=
# POLYMARKET_API_SECRET=
# POLYMARKET_API_PASSPHRASE=

# ─── Risk management ─────────────────────────────────────────────────────────

# Master kill switch — must be explicitly true to allow live order submission.
TRADING_ENABLED=false

# Maximum daily loss as a fraction of starting NAV (0.10 = 10%).
MAX_DAILY_LOSS_PCT=0.10

# Maximum number of simultaneous open positions.
MAX_CONCURRENT_POSITIONS=5

# Maximum USDC per single order.
MAX_SINGLE_ORDER_USDC=20.0

# Maximum orders per second (CLOB rate-limit safety).
MAX_ORDERS_PER_SECOND=3

# ─── Dynamic VaR ─────────────────────────────────────────────────────────────

# Rolling window in seconds for Value-at-Risk exposure tracking.
VAR_WINDOW_SECS=60

# VaR circuit-breaker threshold — trip if rolling exposure > this % of NAV.
VAR_THRESHOLD_PCT=0.05

# ─── In-play failsafe ────────────────────────────────────────────────────────

# Maximum price drift (basis points) during the pre-order countdown.
# 150 = 1.5%. If exceeded, the order is aborted.
PRICE_DRIFT_ABORT_BPS=150

# Poll interval in milliseconds during the failsafe countdown.
FAILSAFE_POLL_INTERVAL_MS=100

# Countdown duration in seconds before submitting a live order.
FAILSAFE_COUNTDOWN_SECS=3

# ─── Game-start watcher ──────────────────────────────────────────────────────

# How often (milliseconds) to poll CLOB prices for in-play detection.
GAME_WATCHER_INTERVAL_MS=500

# ─── Logging ─────────────────────────────────────────────────────────────────

# Tracing filter directive. Examples: info | debug | engine=debug,warn
LOG_LEVEL=info
