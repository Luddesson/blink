# ============================================================================
# Blink Engine — Paper Trading Soak Test Config
# Target: Hetzner CPX22 (or any VPS)
# Purpose: 24h soak test — NO real money, NO credentials needed
#
# EDIT REQUIRED:
#   - RN1_WALLET    → the wallet address you want to track/mirror
#   - MARKETS       → Polymarket token IDs to monitor
# ============================================================================

# ── Endpoints (public, no auth needed for paper mode) ────────────────────────
CLOB_HOST=https://clob.polymarket.com
WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
GAMMA_API=https://gamma-api.polymarket.com

# ── Wallet to track (RN1 — the wallet blink mirrors) ─────────────────────────
# Replace with the actual wallet address you want to shadow
RN1_WALLET=REPLACE_WITH_TARGET_WALLET_ADDRESS

# ── Markets to monitor ────────────────────────────────────────────────────────
# Comma-separated Polymarket token IDs (condition IDs)
# Find them at: https://polymarket.com → open a market → copy the token ID from URL
# Example: MARKETS=0x1234...,0x5678...
MARKETS=REPLACE_WITH_TOKEN_ID_1,REPLACE_WITH_TOKEN_ID_2

# ── Trading Mode ─────────────────────────────────────────────────────────────
PAPER_TRADING=true
LIVE_TRADING=false
TRADING_ENABLED=true
TUI=false

# ── Paper Portfolio ───────────────────────────────────────────────────────────
# Starting virtual balance for paper simulation
PAPER_STARTING_BALANCE_USDC=1000.0

# ── Risk Management ───────────────────────────────────────────────────────────
MAX_DAILY_LOSS_PCT=0.10
MAX_CONCURRENT_POSITIONS=10
MAX_SINGLE_ORDER_USDC=50.0
MAX_ORDERS_PER_SECOND=2

# ── Observability ────────────────────────────────────────────────────────────
LOG_LEVEL=info
CLICKHOUSE_URL=http://127.0.0.1:8123
AUTO_POSTRUN_REVIEW=true
POSTRUN_REVIEW_DIR=logs/reports

# ── WebSocket Resilience ─────────────────────────────────────────────────────
WS_RECONNECT_DEBOUNCE_MS=2000

# ── Reconciliation ────────────────────────────────────────────────────────────
LIVE_RECONCILE_INTERVAL_SECS=10

# ── Live config (not used in paper mode — kept for schema compatibility) ──────
LIVE_TRADING=false
BLINK_LIVE_PROFILE=canonical-v1
LIVE_ROLLOUT_STAGE=1
LIVE_CANARY_MAX_ORDER_USDC=50.0
LIVE_CANARY_MAX_ORDERS_PER_SESSION=999
LIVE_CANARY_DAYTIME_ONLY=false
LIVE_CANARY_START_HOUR_UTC=0
LIVE_CANARY_END_HOUR_UTC=23
LIVE_CANARY_MAX_REJECT_STREAK=10

# ── Credentials (NOT needed for paper mode — leave empty) ────────────────────
SIGNER_PRIVATE_KEY=
POLYMARKET_FUNDER_ADDRESS=0x0000000000000000000000000000000000000000
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_SIGNATURE_TYPE=1
POLYMARKET_ORDER_NONCE=0
POLYMARKET_ORDER_EXPIRATION=0
