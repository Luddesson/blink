STEP 7 — AWS NITRO ENCLAVE (Key Security)
═══════════════════════════════════════════════════════════════

  # Prerequisites: EC2 instance with Nitro support (most modern instances)
  
  # Enable Nitro Enclaves on the instance:
  # In EC2 console: Actions > Instance Settings > Change Nitro Enclave > Enable
  
  # Install Nitro Enclaves CLI:
  apt install aws-nitro-enclaves-cli aws-nitro-enclaves-cli-devel
  systemctl start nitro-enclaves-allocator
  systemctl enable nitro-enclaves-allocator
  
  # Build enclave image (contains key + signing logic):
  # Create Dockerfile for the signing service:
  # FROM rust:latest
  # COPY ./signer /app/signer
  # ENTRYPOINT ["/app/signer"]
  
  nitro-cli build-enclave \
      --docker-uri blink-signer:latest \
      --output-file blink-signer.eif
  
  # Run enclave (allocate 512MB RAM, 2 vCPUs):
  nitro-cli run-enclave \
      --eif-path blink-signer.eif \
      --memory 512 \
      --cpu-count 2 \
      --enclave-cid 16
  
  # Main engine communicates with enclave via vsock:
  # vsock address: CID=16, port=5000
  # Send: unsigned order data
  # Receive: EIP-712 signature bytes
  # Private key NEVER leaves the enclave — verified by AWS attestation

