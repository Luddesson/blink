3. ORDER BOOK DATA STRUCTURE — CACHE-FRIENDLY DESIGN
═══════════════════════════════════════════════════════════════

The order book is accessed millions of times per second. It must live in
L1 CPU cache (~32KB). Design it around cache lines (64 bytes each).

// Price as u64 (multiply by 1000 to avoid float) — 8 bytes
// Size as u64 — 8 bytes
// = 16 bytes per level, 4 levels per cache line

#[repr(C, align(64))]    // align to cache line boundary
struct PriceLevel {
    price: u64,          // price × 1000 (e.g. 0.65 → 650)
    size:  u64,          // total size at this level
}

struct OrderBook {
    // BTreeMap gives O(log n) updates and O(1) best-bid/best-ask
    bids: std::collections::BTreeMap<u64, u64>,   // price → size
    asks: std::collections::BTreeMap<u64, u64>,
    token_id: String,
}

impl OrderBook {
    fn best_bid(&self) -> Option<(u64, u64)> {
        self.bids.iter().next_back().map(|(&p, &s)| (p, s))
    }
    fn best_ask(&self) -> Option<(u64, u64)> {
        self.asks.iter().next().map(|(&p, &s)| (p, s))
    }
    fn spread_bps(&self) -> Option<u64> {
        let (bid, _) = self.best_bid()?;
        let (ask, _) = self.best_ask()?;
        Some((ask - bid) * 10000 / bid)  // spread in basis points
    }
    // Apply WebSocket delta update
    fn apply_delta(&mut self, side: Side, price: u64, size: u64) {
        let book = match side {
            Side::Buy  => &mut self.bids,
            Side::Sell => &mut self.asks,
        };
        if size == 0 {
            book.remove(&price);  // level removed
        } else {
            book.insert(price, size);
        }
    }
}

