6. WEBSOCKET CONNECTION MANAGEMENT
═══════════════════════════════════════════════════════════════

Production WebSocket connections die. Build reconnect logic from day 1.

use tokio_tungstenite::{connect_async, tungstenite::Message};
use tokio::time::{sleep, Duration};
use futures::{SinkExt, StreamExt};

async fn connect_with_retry(url: &str) -> WebSocketStream<...> {
    let mut delay = Duration::from_millis(100);
    loop {
        match connect_async(url).await {
            Ok((ws, _)) => {
                tracing::info!("WebSocket connected: {}", url);
                return ws;
            }
            Err(e) => {
                tracing::warn!("WS connect failed: {}. Retry in {:?}", e, delay);
                sleep(delay).await;
                delay = (delay * 2).min(Duration::from_secs(30)); // backoff cap
            }
        }
    }
}

// CRITICAL: Set TCP_NODELAY to disable Nagle's algorithm
// This ensures small packets (order messages) are sent immediately, not buffered
// tokio-tungstenite does this via connect_async_tls_with_config:
use tokio_tungstenite::tungstenite::protocol::WebSocketConfig;
let config = WebSocketConfig {
    max_message_size: Some(64 << 20),   // 64MB
    ..Default::default()
};
// The disable_nagle parameter in connect_async_with_config handles TCP_NODELAY

// Keep-alive heartbeat loop:
tokio::spawn(async move {
    let mut interval = tokio::time::interval(Duration::from_secs(30));
    loop {
        interval.tick().await;
        if ws_sink.send(Message::Ping(vec![])).await.is_err() {
            break;  // connection dead, trigger reconnect
        }
    }
});

