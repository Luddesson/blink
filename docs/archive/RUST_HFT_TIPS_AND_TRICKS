9. ERROR HANDLING PATTERNS FOR TRADING SYSTEMS
═══════════════════════════════════════════════════════════════

Rule: NEVER panic in production. NEVER use .unwrap() outside tests.
A panic kills the entire trading engine.

// Define typed error enum — zero-cost at runtime
#[derive(thiserror::Error, Debug)]
enum EngineError {
    #[error("WebSocket disconnected: {0}")]
    WsDisconnected(String),
    #[error("Order rejected by CLOB: {code} - {message}")]
    OrderRejected { code: u16, message: String },
    #[error("Signing failed: {0}")]
    SigningFailed(String),
    #[error("Rate limit exceeded — backing off")]
    RateLimited,
}

// Use ? operator for propagation, match for critical paths
async fn safe_submit(order: Order) -> Result<OrderId, EngineError> {
    let response = clob_client
        .post_order(&order)
        .await
        .map_err(|e| EngineError::WsDisconnected(e.to_string()))?;

    if response.status == 429 {
        return Err(EngineError::RateLimited);
    }
    Ok(response.order_id)
}

