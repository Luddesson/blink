10. LATENCY BENCHMARKING — MEASURE EVERYTHING
═══════════════════════════════════════════════════════════════

Add precise timestamps at every stage of the pipeline.
Use std::time::Instant (monotonic, nanosecond resolution).

struct PipelineTimer {
    ws_received:      Instant,
    parsed:           Option<Instant>,
    rn1_detected:     Option<Instant>,
    order_built:      Option<Instant>,
    order_signed:     Option<Instant>,
    order_submitted:  Option<Instant>,
}

impl PipelineTimer {
    fn log_latencies(&self) {
        if let (Some(p), Some(d), Some(b), Some(s), Some(sub)) =
            (self.parsed, self.rn1_detected, self.order_built,
             self.order_signed, self.order_submitted)
        {
            tracing::info!(
                parse_us     = (p - self.ws_received).as_micros(),
                detect_us    = (d - self.ws_received).as_micros(),
                build_us     = (b - self.ws_received).as_micros(),
                sign_us      = (s - self.ws_received).as_micros(),
                total_us     = (sub - self.ws_received).as_micros(),
                "pipeline latency"
            );
        }
    }
}

Target latency budget:
  WS message receive → parse:        < 50μs
  Parse → RN1 detection:             < 10μs
  Detection → order build:           < 100μs
  Order build → EIP-712 sign:        < 500μs  (crypto is expensive!)
  Sign → HTTP POST submitted:        < 2ms
  TOTAL end-to-end:                  < 5ms

