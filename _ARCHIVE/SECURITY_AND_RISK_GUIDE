  function invariant_exposureNeverExceedsNAV() public {
      assertLe(
          engine.totalOpenExposure(),
          engine.portfolioNAV() * MAX_EXPOSURE_BPS / 10000
      );
  }

  // Run: forge test --invariant-runs 100000

