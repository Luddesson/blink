1. MEMORY MANAGEMENT — KILL THE ALLOCATOR ON HOT PATH
═══════════════════════════════════════════════════════════════

Every heap allocation (Box, Vec::push, String) on the hot path is a potential
microsecond-scale delay. Pre-allocate everything at startup.

BAD (allocates on every message):
  fn process_order(msg: &str) {
      let parsed: OrderMsg = serde_json::from_str(msg).unwrap();
      let orders: Vec<Order> = vec![];
      // ...
  }

GOOD (pre-allocated, reused buffers):
  struct Engine {
      parse_buf: Vec<u8>,         // reused buffer for simd-json
      order_pool: Vec<Order>,     // pre-allocated order pool
  }

  impl Engine {
      fn new() -> Self {
          Self {
              parse_buf: Vec::with_capacity(65536),  // 64KB
              order_pool: Vec::with_capacity(100),
          }
      }
  }

Use jemalloc as global allocator:
  use jemallocator::Jemalloc;
  #[global_allocator]
  static GLOBAL: Jemalloc = Jemalloc;

