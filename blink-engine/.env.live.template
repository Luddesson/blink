# ═══════════════════════════════════════════════════════════════════════════════
# Blink Engine — LIVE TRADING Configuration Template
# ═══════════════════════════════════════════════════════════════════════════════
#
# SETUP STEPS:
# 1. Generate wallet:  cargo run -p engine -- --generate-wallet --save data/keystore.json
# 2. Register on Polymarket with the generated address
# 3. Fund your Polymarket account with USDC on Polygon
# 4. Get API credentials from Polymarket CLOB
# 5. Encrypt credentials:  cargo run -p engine -- --encrypt-key data/keystore.json
# 6. Copy this file to .env and fill in the values
# 7. Preflight check:  cargo run --release -p engine -- --preflight-live
# 8. Start canary:  cargo run --release -p engine
#
# ═══════════════════════════════════════════════════════════════════════════════

# ── Core Mode ─────────────────────────────────────────────────────────────────
LIVE_TRADING=true
TRADING_ENABLED=true
PAPER_TRADING=false
BLINK_LIVE_PROFILE=canonical-v1

# ── Credentials (Option A: Encrypted Keystore — RECOMMENDED) ─────────────────
# KEYSTORE_PATH=data/keystore.json
# KEYSTORE_PASSPHRASE=your-strong-passphrase-here

# ── Credentials (Option B: Plain Environment Variables) ───────────────────────
# SIGNER_PRIVATE_KEY=            # 64 hex chars (no 0x prefix)
# POLYMARKET_FUNDER_ADDRESS=     # 0x-prefixed, 42 chars (Polymarket proxy wallet)
# POLYMARKET_API_KEY=            # From Polymarket CLOB API registration
# POLYMARKET_API_SECRET=         # Base64-encoded secret
# POLYMARKET_API_PASSPHRASE=     # API passphrase

# ── Order Signing ─────────────────────────────────────────────────────────────
POLYMARKET_SIGNATURE_TYPE=0      # 0 = EOA (default), 1-2 = account models
# POLYMARKET_ORDER_NONCE=0       # Auto-managed by persistent nonce file
# POLYMARKET_ORDER_EXPIRATION=0  # 0 = GTC (Good Till Cancel)

# ── Canary Stage 1 (First 1-3 days) ──────────────────────────────────────────
LIVE_ROLLOUT_STAGE=1
LIVE_CANARY_MAX_ORDER_USDC=5.0
LIVE_CANARY_MAX_ORDERS_PER_SESSION=20
LIVE_CANARY_DAYTIME_ONLY=true
LIVE_CANARY_START_HOUR_UTC=8
LIVE_CANARY_END_HOUR_UTC=22
LIVE_CANARY_MAX_REJECT_STREAK=3
# LIVE_CANARY_ALLOWED_MARKETS=   # Comma-separated token IDs (empty = all)

# ── Risk Management ──────────────────────────────────────────────────────────
MAX_SINGLE_ORDER_USDC=5.0
MAX_DAILY_LOSS_PCT=0.03          # 3% max daily loss
MAX_CONCURRENT_POSITIONS=3
VAR_THRESHOLD_PCT=0.03
MAX_ORDERS_PER_SECOND=1

# ── Strategy (tuned from paper trading) ───────────────────────────────────────
PAPER_MAX_ORDER_USDC=4.0
PAPER_MIN_TRADE_USDC=2.0
PAPER_MIN_ORDER_FLOOR_USDC=2.0
PAPER_SIZE_MULTIPLIER=0.05
PAPER_MAX_POSITION_PCT=0.12
PAPER_CONFIDENCE_DISCOUNT=0.50
CASH_RESERVE_PCT=0.15
ENTRY_DELAY_SECS=30

# ── Exit Strategy ─────────────────────────────────────────────────────────────
STOP_LOSS_PCT=0.40
EXIT_SLIPPAGE_BPS=100
AUTOCLAIM_TIER_1_PCT=60
AUTOCLAIM_TIER_2_PCT=100
AUTOCLAIM_TIER_3_PCT=150
MOMENTUM_GRACE_SECS=60

# ── Network & WebSocket ──────────────────────────────────────────────────────
CLOB_HOST=https://clob.polymarket.com
WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
LIVE_RECONCILE_INTERVAL_SECS=10
WS_RECONNECT_DEBOUNCE_MS=500

# ── RN1 Target ────────────────────────────────────────────────────────────────
# RN1_WALLET=                    # Lowercase hex whale wallet to shadow
# MARKETS=                       # Comma-separated token IDs (or leave empty for dynamic)

# ── Observability ─────────────────────────────────────────────────────────────
RUST_LOG=info,engine=debug
WEB_UI=true

# ═══════════════════════════════════════════════════════════════════════════════
# CANARY STAGE 2 (after Stage 1 success — 3-7 days):
# LIVE_ROLLOUT_STAGE=2
# LIVE_CANARY_MAX_ORDER_USDC=8.0
# LIVE_CANARY_MAX_ORDERS_PER_SESSION=100
# LIVE_CANARY_DAYTIME_ONLY=false
# MAX_SINGLE_ORDER_USDC=8.0
# MAX_DAILY_LOSS_PCT=0.05
# MAX_CONCURRENT_POSITIONS=5
#
# FULL PRODUCTION (after Stage 2 success):
# LIVE_ROLLOUT_STAGE=3
# (Remove all canary limits)
# ═══════════════════════════════════════════════════════════════════════════════
