8. THE 3-SECOND FAILSAFE — CORRECT IMPLEMENTATION
═══════════════════════════════════════════════════════════════

This is the most critical safety mechanism. Get it wrong and you lose money.

use tokio::time::{timeout, Duration, interval};

async fn submit_with_failsafe(
    order_id: String,
    token_id: String,
    entry_price: u64,
    clob: Arc<ClobClient>,
    price_feed: Arc<PriceFeed>,
) -> Result<(), Error> {
    // Submit the order
    clob.post_order(&order_id).await?;

    // Spawn failsafe watchdog
    let order_id_clone = order_id.clone();
    let clob_clone = Arc::clone(&clob);

    tokio::spawn(async move {
        let mut poll = interval(Duration::from_millis(100));
        let deadline = timeout(Duration::from_secs(3), async {
            loop {
                poll.tick().await;

                let current_price = price_feed.get_price(&token_id).await;
                let drift_bps = abs_diff_bps(entry_price, current_price);

                if drift_bps > 150 {  // 1.5% drift threshold
                    tracing::warn!(
                        "Failsafe triggered: drift {}bps, cancelling {}",
                        drift_bps, order_id_clone
                    );
                    let _ = clob_clone.cancel_order(&order_id_clone).await;
                    return;
                }
            }
        });

        // Regardless of outcome, watchdog exits after 3 seconds
        let _ = deadline.await;
    });

    Ok(())
}

fn abs_diff_bps(a: u64, b: u64) -> u64 {
    let diff = if a > b { a - b } else { b - a };
    diff * 10000 / a
}

