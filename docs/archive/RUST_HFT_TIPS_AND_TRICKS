// BAD:
tokio::spawn(async {
    std::thread::sleep(Duration::from_millis(1));  // blocks the thread!
});
// GOOD:
tokio::spawn(async {
    tokio::time::sleep(Duration::from_millis(1)).await;  // cooperative yield
});

