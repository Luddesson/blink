STEP 8 — CI/CD PIPELINE (GitHub Actions)
═══════════════════════════════════════════════════════════════

.github/workflows/deploy.yml:

name: Build, Test, Deploy

on:
  push:
    branches: [main]

jobs:
  test:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: dtolnay/rust-toolchain@stable
      - name: Build release
        run: cargo build --release
      - name: Run unit tests
        run: cargo test
      - name: Run Foundry fuzz tests
        run: forge test --fuzz-runs 10000
      - name: Dry-run against Reth testnet fork
        run: cargo run --bin dry_run -- --fork-url ${{ secrets.RETH_RPC }}

  deploy:
    needs: test
    runs-on: ubuntu-latest
    steps:
      - name: Deploy to prod server
        run: |
          ssh prod-server "
            cd /opt/blink &&
            git pull &&
            cargo build --release &&
            systemctl restart blink-engine
          "

