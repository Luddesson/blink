STEP 5 — CLICKHOUSE SETUP (Tick Data Warehouse)
═══════════════════════════════════════════════════════════════

  # Install ClickHouse:
  apt install clickhouse-server clickhouse-client
  systemctl start clickhouse-server

  # Create order book tick table:
  CREATE TABLE orderbook_ticks (
      timestamp    DateTime64(6),       -- microsecond precision
      token_id     String,
      side         Enum8('bid'=0, 'ask'=1),
      price        UInt64,              -- price × 1000
      size         UInt64,
      market_event String               -- 'new'|'update'|'remove'
  ) ENGINE = MergeTree()
  ORDER BY (token_id, timestamp)
  PARTITION BY toYYYYMMDD(timestamp);

  # Create trades table (RN1 detected trades):
  CREATE TABLE rn1_trades (
      detected_at  DateTime64(6),
      token_id     String,
      side         Enum8('buy'=0, 'sell'=1),
      price        UInt64,
      size         UInt64,
      our_order_id String,
      our_fill     UInt64,
      pnl_usdc     Int64                -- realized P&L in USDC cents
  ) ENGINE = MergeTree()
  ORDER BY detected_at;

