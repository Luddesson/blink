# ============================================================================
# Blink Engine — Stage 1 Canary Live Profile
# Copy to .env and fill in credentials before enabling LIVE_TRADING.
#
# Pre-live checklist (must ALL be verified):
#   [ ] USDC.e funded on Polygon (contract: 0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174)
#   [ ] Allowance to CTF Exchange (0x4bFb41d5B3570DeFd03C39a9A4D8dE6Bd8B8982E) confirmed
#   [ ] API credentials derived via createOrDeriveApiKey
#   [ ] POLYMARKET_SIGNATURE_TYPE matches wallet type (0=EOA, 1=POLY_PROXY, 2=GNOSIS_SAFE)
#   [ ] Run with LIVE_TRADING=false first and verify paper orders flow correctly
#   [ ] Run BLINK_LIVE_PROFILE=canonical-v1 preflight check passes
#   [ ] TRADING_ENABLED=true set ONLY after all checks pass
# ============================================================================

# ─── WebSocket & REST endpoints ──────────────────────────────────────────────

CLOB_HOST=https://clob.polymarket.com
WS_URL=wss://ws-live-data.polymarket.com
GAMMA_API=https://gamma-api.polymarket.com

# ─── Tracking target ─────────────────────────────────────────────────────────

RN1_WALLET=0x2005d16a84ceefa912d4e380cd32e7ff827875ea

# ─── Markets ─────────────────────────────────────────────────────────────────
# Run: cargo run -p market-scanner -- to discover active token IDs.
MARKETS=REPLACE_WITH_TOKEN_IDS

# ─── Operating mode ──────────────────────────────────────────────────────────

PAPER_TRADING=false
TUI=false
LIVE_TRADING=true

# Canonical live profile — must not change in production.
BLINK_LIVE_PROFILE=canonical-v1

# Stage 1 canary: very conservative limits.
# Stage 1 → Stage 2: after 20 clean sessions with zero reconciliation drift.
# Stage 2 → Stage 3: after risk committee sign-off.
LIVE_ROLLOUT_STAGE=1
LIVE_CANARY_MAX_ORDER_USDC=5.0
LIVE_CANARY_MAX_ORDERS_PER_SESSION=10
LIVE_CANARY_DAYTIME_ONLY=true
LIVE_CANARY_START_HOUR_UTC=8
LIVE_CANARY_END_HOUR_UTC=22
LIVE_CANARY_MAX_REJECT_STREAK=3
# Optional: restrict to known-good markets only in Stage 1.
# LIVE_CANARY_ALLOWED_MARKETS=TOKEN_ID_1,TOKEN_ID_2

# ─── Live trading credentials ─────────────────────────────────────────────────

# 64-character hex private key for EIP-712 order signing (no 0x prefix).
SIGNER_PRIVATE_KEY=REPLACE_WITH_64_HEX_CHARS

# Polymarket funder / proxy-wallet address (the order `maker`).
POLYMARKET_FUNDER_ADDRESS=0xYOUR_FUNDER_ADDRESS

# Polymarket L2 API credentials (from createOrDeriveApiKey endpoint).
POLYMARKET_API_KEY=REPLACE_WITH_API_KEY
POLYMARKET_API_SECRET=REPLACE_WITH_BASE64_SECRET
POLYMARKET_API_PASSPHRASE=REPLACE_WITH_PASSPHRASE

# Signature type:
#   0 = EOA (direct private key, no proxy)
#   1 = POLY_PROXY (most common for browser-derived wallets)
#   2 = GNOSIS_SAFE
POLYMARKET_SIGNATURE_TYPE=0

# Nonce: 0 = auto-increment per order (recommended).
POLYMARKET_ORDER_NONCE=0

# Expiration: 0 = GTC (good-til-cancelled, no expiry).
POLYMARKET_ORDER_EXPIRATION=0

# ─── Master kill switch ───────────────────────────────────────────────────────
# MUST be explicitly set to true — engine will refuse to place live orders otherwise.
TRADING_ENABLED=true

# ─── Risk management ─────────────────────────────────────────────────────────

# Hard daily-loss limit: 10% of starting NAV.
MAX_DAILY_LOSS_PCT=0.10

# Max simultaneous open positions. Stage 1: limit to 3.
MAX_CONCURRENT_POSITIONS=3

# Per-order cap: must be ≤ LIVE_CANARY_MAX_ORDER_USDC for Stage 1.
MAX_SINGLE_ORDER_USDC=5.0

# Max orders per second (CLOB rate-limit safety).
MAX_ORDERS_PER_SECOND=2

# ─── In-play failsafe ────────────────────────────────────────────────────────

# Abort if price drifts >1.5% during the countdown window.
PRICE_DRIFT_ABORT_BPS=150
FAILSAFE_POLL_INTERVAL_MS=100
FAILSAFE_COUNTDOWN_SECS=3

# ─── Autoclaim ───────────────────────────────────────────────────────────────

# Tiered exit: lock 30% at +40%, 30% at +70%, close remaining at +100%.
AUTOCLAIM_ENABLED=true
AUTOCLAIM_TIERS=40:0.30,70:0.30,100:1.0

# ─── Reconciliation ──────────────────────────────────────────────────────────

# Poll interval for exchange order status reconciliation (seconds).
LIVE_RECONCILE_INTERVAL_SECS=10

# ─── Agent RPC (optional) ─────────────────────────────────────────────────────

AGENT_RPC_ENABLED=true
AGENT_RPC_BIND=127.0.0.1:7878

# ─── Observability ───────────────────────────────────────────────────────────

LOG_LEVEL=info
AUTO_POSTRUN_REVIEW=true
POSTRUN_REVIEW_DIR=logs/reports
PAPER_STATE_PATH=logs/paper_portfolio_state.json

# Optional: ClickHouse for real-time execution analytics.
# CLICKHOUSE_URL=http://127.0.0.1:8123

# ─── VaR circuit breaker ──────────────────────────────────────────────────────

VAR_WINDOW_SECS=60
VAR_THRESHOLD_PCT=0.05
