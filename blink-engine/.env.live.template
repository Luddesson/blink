# ============================================================================
# Blink Engine — LIVE TRADING Environment Template
#
# Copy to /etc/blink-engine.env and fill ALL values.
# File MUST be owned by root and chmod 600 (secrets protection).
#
#   sudo cp .env.live.template /etc/blink-engine.env
#   sudo chmod 600 /etc/blink-engine.env
#   sudo chown root:root /etc/blink-engine.env
#
# Before going live, run preflight:
#   cargo run --release -p engine -- --preflight-live
# ============================================================================

# ─── Endpoints ───────────────────────────────────────────────────────────────
CLOB_HOST=https://clob.polymarket.com
WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
GAMMA_API=https://gamma-api.polymarket.com

# ─── Target wallet ───────────────────────────────────────────────────────────
RN1_WALLET=0x2005d16a84ceefa912d4e380cd32e7ff827875ea

# ─── Markets (comma-separated token IDs) ────────────────────────────────────
# Run: cargo run -p market-scanner  to discover current active markets
MARKETS=REPLACE_WITH_TOKEN_IDS

# ─── Operating mode ──────────────────────────────────────────────────────────
LIVE_TRADING=true
PAPER_TRADING=false
TUI=false

# ─── Canonical live profile (DO NOT CHANGE) ──────────────────────────────────
BLINK_LIVE_PROFILE=canonical-v1
TRADING_ENABLED=true

# ─── Canary rollout stage ─────────────────────────────────────────────────────
# Stage 1: conservative start ($5/order, max 20 orders, daytime UTC 8-22)
# Stage 2: increase after clean sessions (adjust below)
# Stage 3: full target
LIVE_ROLLOUT_STAGE=1
LIVE_CANARY_MAX_ORDER_USDC=5.0
LIVE_CANARY_MAX_ORDERS_PER_SESSION=20
LIVE_CANARY_DAYTIME_ONLY=true
LIVE_CANARY_START_HOUR_UTC=8
LIVE_CANARY_END_HOUR_UTC=22
LIVE_CANARY_MAX_REJECT_STREAK=3
# Allowlist specific markets during stage 1 (recommended):
# LIVE_CANARY_ALLOWED_MARKETS=TOKEN_ID_1,TOKEN_ID_2

# ─── Live credentials (FILL THESE IN) ────────────────────────────────────────
# Obtain API key/secret/passphrase from Polymarket via createOrDeriveApiKey.
# See: https://docs.polymarket.com/developers/CLOB/authentication
SIGNER_PRIVATE_KEY=REPLACE_WITH_64_HEX_CHARS
POLYMARKET_FUNDER_ADDRESS=0xREPLACE_WITH_YOUR_PROXY_WALLET_ADDRESS
POLYMARKET_API_KEY=REPLACE_WITH_API_KEY
POLYMARKET_API_SECRET=REPLACE_WITH_BASE64_SECRET
POLYMARKET_API_PASSPHRASE=REPLACE_WITH_PASSPHRASE

# EIP-712 signature type:
#   0 = EOA (direct wallet)
#   1 = POLY_PROXY (most common for funded accounts)
#   2 = GNOSIS_SAFE
POLYMARKET_SIGNATURE_TYPE=1

# Nonce strategy: 0 = auto-increment per order (recommended)
POLYMARKET_ORDER_NONCE=0

# Expiration: 0 = GTC (good-til-cancelled). Set to future unix timestamp for GTD.
POLYMARKET_ORDER_EXPIRATION=0

# ─── Risk management ─────────────────────────────────────────────────────────
MAX_DAILY_LOSS_PCT=0.10
MAX_CONCURRENT_POSITIONS=5
MAX_SINGLE_ORDER_USDC=5.0
MAX_ORDERS_PER_SECOND=2

# ─── Observability ───────────────────────────────────────────────────────────
LOG_LEVEL=info
CLICKHOUSE_URL=http://localhost:8123
AUTO_POSTRUN_REVIEW=true
POSTRUN_REVIEW_DIR=logs/reports

# ─── Reconciliation ──────────────────────────────────────────────────────────
# How often (seconds) to poll exchange for pending order status.
LIVE_RECONCILE_INTERVAL_SECS=10

# ─── WebSocket resilience ────────────────────────────────────────────────────
WS_RECONNECT_DEBOUNCE_MS=1500

# ─── Agent RPC (optional — for monitoring/control) ───────────────────────────
AGENT_RPC_ENABLED=false
AGENT_RPC_BIND=127.0.0.1:7878

# ─── eBPF kernel telemetry (Linux only, requires CAP_BPF or root) ────────────
EBPF_TELEMETRY=false
