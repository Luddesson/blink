# ─────────────────────────────────────────────────────────────────
#  Blink Engine — Production .env Template (Hetzner)
#  Copy to /opt/blink/.env and fill in secrets
# ─────────────────────────────────────────────────────────────────

# ── Mode ────────────────────────────────────────────────────────
PAPER_TRADING=true
TRADING_ENABLED=true
# LIVE_TRADING=true               # Uncomment for live mode
# BLINK_LIVE_PROFILE=canonical-v1 # Required for live mode

# ── RN1 whale tracking ─────────────────────────────────────────
RN1_WALLET=0x2005d16a84ceefa912d4e380cd32e7ff827875ea

# ── Markets (auto-populated by poller, or set manually) ────────
# MARKETS=token1,token2

# ── Sizing & risk ───────────────────────────────────────────────
SIZE_MULTIPLIER=0.10
PAPER_MAX_ORDER_USDC=5
PAPER_MIN_TRADE_USDC=1
PAPER_MIN_ORDER_FLOOR_USDC=2
MIN_SIGNAL_NOTIONAL_USD=3
MAX_CONCURRENT_POSITIONS=20
MAX_SINGLE_ORDER_USDC=25
MAX_DAILY_LOSS_PCT=100
VAR_THRESHOLD_PCT=100
MAX_ORDERS_PER_SECOND=10

# ── Exit strategy ───────────────────────────────────────────────
STOP_LOSS_PCT=50
STOP_LOSS_SMALL_PCT=50
MAX_HOLD_SECS=21600
# AUTOCLAIM_TIERS=60:0.30,100:0.30,150:1.0

# ── Web UI ──────────────────────────────────────────────────────
WEB_UI=true
WEB_UI_PORT=3030
WEB_UI_BIND=127.0.0.1
WS_BROADCAST_INTERVAL_SECS=1

# ── Alpha AI Sidecar ───────────────────────────────────────────
ALPHA_ENABLED=true
ALPHA_SIDECAR_URL=http://127.0.0.1:7879
AGENT_RPC_ENABLED=true
AGENT_RPC_BIND=127.0.0.1:7878
ALPHA_TRADING_ENABLED=true
ALPHA_MAX_CONCURRENT_POSITIONS=5
ALPHA_MAX_DAILY_LOSS_PCT=100

# ── Alpha Sidecar Config ───────────────────────────────────────
BLINK_RPC_URL=http://127.0.0.1:7878
OPENAI_API_KEY=sk-CHANGE_ME
# XAI_API_KEY=                    # For Grok (alternative)
# LLM_BASE_URL=https://api.openai.com/v1
ALPHA_CONFIDENCE_FLOOR=0.45
ALPHA_MIN_EDGE_BPS=150
ALPHA_SCAN_INTERVAL_SECS=90
ALPHA_MAX_EXPIRY_HOURS=6
ALPHA_DB_PATH=/opt/blink/data/alpha_predictions.db

# ── Logging ─────────────────────────────────────────────────────
RUST_LOG=info,engine=info
LOG_DIR=/opt/blink/logs
AUTO_POSTRUN_REVIEW=true

# ── Paper trading realism ───────────────────────────────────────
PAPER_REALISM_MODE=true
PAPER_ENTRY_SPREAD_BPS=5
PAPER_EXIT_SLIPPAGE_BPS=10

# ── Paths (Linux) ──────────────────────────────────────────────
PAPER_PORTFOLIO_PATH=/opt/blink/data/paper_portfolio_state.json
WARM_STATE_PATH=/opt/blink/data/paper_warm_state.json

# ── Live mode secrets (uncomment when going live) ──────────────
# KEYSTORE_PATH=/opt/blink/data/keystore.json
# KEYSTORE_PASSPHRASE=CHANGE_ME
# POLYMARKET_API_KEY=
# POLYMARKET_API_SECRET=
# POLYMARKET_PASSPHRASE=
